# Core app
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
WEB_PORT=3000
NEXT_TELEMETRY_DISABLED=1

# Database (PostgreSQL)
POSTGRES_DB=vb_jewelry_ai
POSTGRES_USER=vb_user
POSTGRES_PASSWORD=vb_password
DATABASE_URL=postgresql://vb_user:vb_password@localhost:5433/vb_jewelry_ai?schema=public

# Redis
REDIS_URL=redis://localhost:6380

# OpenAI (Phase 3 content idea generation)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_TIMEOUT_MS=60000
OPENAI_IMAGE_RETRY_COUNT=1
OPENAI_IMAGE_RETRY_DELAY_MS=1200
OPENAI_PRODUCT_IMAGE_MATCH_MIN_SCORE=0.86
OPENAI_PRODUCT_IMAGE_MAX_ATTEMPTS=3
OPENAI_PRODUCT_IMAGE_RETRY_DELAY_MS=1200

# AI worker queue
AI_QUEUE_POLL_INTERVAL_MS=5000
AI_JOB_MAX_ATTEMPTS=3
AI_JOB_BACKOFF_MS=4000
